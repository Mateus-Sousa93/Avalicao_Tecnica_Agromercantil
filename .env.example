# ============================================
# CONFIGURAÇÃO DATABASE - VPS POSTGRESQL
# ============================================
# Para VPS própria (economia Supabase)
DATABASE_URL=postgresql://agro_user:sua_senha_segura@localhost:5432/agromercantil

# ============================================
# CONFIGURAÇÃO ALTERNATIVA - SUPABASE
# ============================================
# Descomente se for usar Supabase ao invés de VPS
# SUPABASE_URL=https://seu-projeto.supabase.co
# SUPABASE_KEY=sua-chave-aqui

# ============================================
# GOOGLE GEMINI API (Agente AI)
# ============================================
GEMINI_API_KEY=sua-chave-gemini-aqui

# ============================================
# CONFIGURAÇÕES GERAIS
# ============================================
BATCH_SIZE=1000
DEBUG=False

# ============================================
# CONFIGURAÇÃO VPS (para deploy)
# ============================================
# VPS_IP=seu.ip.aqui
# VPS_USER=ubuntu
# VPS_PORT=22
